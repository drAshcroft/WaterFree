<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="WaterFree"
    Manufacturer="WaterFree"
    Version="$(var.ProductVersion)"
    ProductCode="*"
    UpgradeCode="{D9B41B5B-30A8-4E37-8C8D-0E67E81A6BA4}"
    Scope="perUser">
    <!-- ProductCode="*" -> a fresh GUID every build. Without it, two builds
         share a ProductCode and Windows Installer treats a reinstall as
         "maintenance mode": it skips RemoveExistingProducts and the
         RunInstallerHelper custom action, leaving every payload file stale.
         With a unique ProductCode + bumped Version, MajorUpgrade removes the
         old product and installs the new one cleanly (helper runs, runtime
         re-extracts). -->
    <MajorUpgrade AllowDowngrades="no" DowngradeErrorMessage="A newer version of WaterFree is already installed." />
    <!-- EmbedCab="yes" so the MSI is self-contained; no separate cab*.cab file needs to ship alongside it. -->
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="LocalAppDataFolder">
        <Directory Id="INSTALLDIR" Name="WaterFree">
        <Directory Id="BinDir" Name="bin">
          <Component Id="RuntimePayload" Guid="{5A4E2E1C-1C9E-4C6B-9B8A-18B1F5F9D4A1}">
            <File Id="RuntimeZipFile" Source="$(var.PayloadDir)\waterfree-runtime.zip" KeyPath="no" />
            <RegistryValue Root="HKCU" Key="Software\WaterFree\Components" Name="RuntimePayload" Type="string" Value="1" KeyPath="yes" />
            <!-- Add the bin dir to user PATH so `waterfree <area> <action>` works in any shell. -->
            <Environment Id="AddWaterfreeToUserPath"
                         Name="PATH"
                         Action="set"
                         Permanent="no"
                         Part="last"
                         System="no"
                         Value="[BinDir]" />
          </Component>
          <Component Id="InstallerHelper" Guid="{8C2B3F4D-7A8F-4D2D-9F6A-3D4A8E6F1B21}">
            <File Id="InstallerHelperExe" Source="$(var.PayloadDir)\waterfree-installer-helper.exe" KeyPath="no" />
            <RegistryValue Root="HKCU" Key="Software\WaterFree\Components" Name="InstallerHelperExe" Type="string" Value="1" KeyPath="yes" />
          </Component>
        </Directory>
        <Directory Id="VsixDir" Name="vsix">
          <Component Id="VsixPayload" Guid="{B1D2C3E4-5F67-4B8C-9A1B-2C3D4E5F6A70}">
            <File Id="VsixFile" Source="$(var.PayloadDir)\waterfree.vsix" KeyPath="no" />
            <RegistryValue Root="HKCU" Key="Software\WaterFree\Components" Name="VsixPayload" Type="string" Value="1" KeyPath="yes" />
          </Component>
        </Directory>
        <Directory Id="SkillsDir" Name="skills">
          <Directory Id="SkillTutorializeDir" Name="tutorialize">
            <Component Id="SkillTutorializePayload" Guid="{E9B6A1D7-7279-4D12-8EA2-61F74A91C2EF}">
              <File Id="SkillTutorializeFile" Source="$(var.PayloadDir)\skills\tutorialize\SKILL.md" KeyPath="no" />
              <RegistryValue Root="HKCU" Key="Software\WaterFree\Components" Name="SkillTutorializePayload" Type="string" Value="1" KeyPath="yes" />
            </Component>
          </Directory>
          <Directory Id="SkillIndexDir" Name="waterfree-index">
            <Component Id="SkillIndexPayload" Guid="{5BD18C1B-9E00-44F0-B49B-5AD7844DD7B1}">
              <File Id="SkillIndexFile" Source="$(var.PayloadDir)\skills\waterfree-index\SKILL.md" KeyPath="no" />
              <RegistryValue Root="HKCU" Key="Software\WaterFree\Components" Name="SkillIndexPayload" Type="string" Value="1" KeyPath="yes" />
            </Component>
          </Directory>
          <Directory Id="SkillKnowledgeDir" Name="waterfree-knowledge">
            <Component Id="SkillKnowledgePayload" Guid="{F78A4C22-915C-4413-9E2B-279C6BF79045}">
              <File Id="SkillKnowledgeFile" Source="$(var.PayloadDir)\skills\waterfree-knowledge\SKILL.md" KeyPath="no" />
              <RegistryValue Root="HKCU" Key="Software\WaterFree\Components" Name="SkillKnowledgePayload" Type="string" Value="1" KeyPath="yes" />
            </Component>
          </Directory>
          <Directory Id="SkillQaSummaryDir" Name="waterfree-qa-summary">
            <Component Id="SkillQaSummaryPayload" Guid="{448E79FA-2A39-4034-A4A9-7B3B83A3F76F}">
              <File Id="SkillQaSummaryFile" Source="$(var.PayloadDir)\skills\waterfree-qa-summary\SKILL.md" KeyPath="no" />
              <RegistryValue Root="HKCU" Key="Software\WaterFree\Components" Name="SkillQaSummaryPayload" Type="string" Value="1" KeyPath="yes" />
            </Component>
          </Directory>
          <Directory Id="SkillTestingDir" Name="waterfree-testing">
            <Component Id="SkillTestingPayload" Guid="{D6BFE79F-C0D1-4240-854F-2D8D9B72C3EE}">
              <File Id="SkillTestingFile" Source="$(var.PayloadDir)\skills\waterfree-testing\SKILL.md" KeyPath="no" />
              <RegistryValue Root="HKCU" Key="Software\WaterFree\Components" Name="SkillTestingPayload" Type="string" Value="1" KeyPath="yes" />
            </Component>
          </Directory>
          <Directory Id="SkillTodosDir" Name="waterfree-todos">
            <Component Id="SkillTodosPayload" Guid="{B8E0CC54-E706-41C8-B28F-E80520C6481F}">
              <File Id="SkillTodosFile" Source="$(var.PayloadDir)\skills\waterfree-todos\SKILL.md" KeyPath="no" />
              <RegistryValue Root="HKCU" Key="Software\WaterFree\Components" Name="SkillTodosPayload" Type="string" Value="1" KeyPath="yes" />
            </Component>
          </Directory>
        </Directory>
        <Directory Id="LogsDir" Name="logs">
          <Directory Id="InstallerLogsDir" Name="installer">
            <Component Id="InstallerLogFolder" Guid="{7B8B8D2A-1D6C-4A5C-9E1A-5E6E0D3A5A31}">
              <CreateFolder />
              <RegistryValue Root="HKCU" Key="Software\WaterFree\Components" Name="InstallerLogFolder" Type="string" Value="1" KeyPath="yes" />
            </Component>
          </Directory>
        </Directory>
        <Component Id="CleanupFolders" Guid="{0A5B8E2D-5D9F-4E6E-9A42-7B2D1C9E4C3A}">
          <RemoveFolder Id="RemoveBinDir" Directory="BinDir" On="uninstall" />
          <RemoveFolder Id="RemoveVsixDir" Directory="VsixDir" On="uninstall" />
          <RemoveFolder Id="RemoveSkillTutorializeDir" Directory="SkillTutorializeDir" On="uninstall" />
          <RemoveFolder Id="RemoveSkillIndexDir" Directory="SkillIndexDir" On="uninstall" />
          <RemoveFolder Id="RemoveSkillKnowledgeDir" Directory="SkillKnowledgeDir" On="uninstall" />
          <RemoveFolder Id="RemoveSkillQaSummaryDir" Directory="SkillQaSummaryDir" On="uninstall" />
          <RemoveFolder Id="RemoveSkillTestingDir" Directory="SkillTestingDir" On="uninstall" />
          <RemoveFolder Id="RemoveSkillTodosDir" Directory="SkillTodosDir" On="uninstall" />
          <RemoveFolder Id="RemoveSkillsDir" Directory="SkillsDir" On="uninstall" />
          <RemoveFolder Id="RemoveInstallerLogsDir" Directory="InstallerLogsDir" On="uninstall" />
          <RemoveFolder Id="RemoveLogsDir" Directory="LogsDir" On="uninstall" />
          <RemoveFolder Id="RemoveInstallDir" Directory="INSTALLDIR" On="uninstall" />
          <RegistryValue Root="HKCU" Key="Software\WaterFree\Components" Name="CleanupFolders" Type="string" Value="1" KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <Feature Id="MainFeature" Title="WaterFree" Level="1">
      <ComponentRef Id="RuntimePayload" />
      <ComponentRef Id="InstallerHelper" />
      <ComponentRef Id="VsixPayload" />
      <ComponentRef Id="SkillTutorializePayload" />
      <ComponentRef Id="SkillIndexPayload" />
      <ComponentRef Id="SkillKnowledgePayload" />
      <ComponentRef Id="SkillQaSummaryPayload" />
      <ComponentRef Id="SkillTestingPayload" />
      <ComponentRef Id="SkillTodosPayload" />
      <ComponentRef Id="InstallerLogFolder" />
      <ComponentRef Id="CleanupFolders" />
    </Feature>

    <CustomAction Id="SetRunHelper" Property="RunInstallerHelper" Value="--install-dir &quot;[INSTALLDIR].&quot; --vsix &quot;[INSTALLDIR]vsix\waterfree.vsix&quot; --log &quot;[TempFolder]WaterFreeInstaller-helper.log&quot;" />
    <CustomAction Id="RunInstallerHelper" FileRef="InstallerHelperExe" ExeCommand="[RunInstallerHelper]" Execute="deferred" Impersonate="yes" Return="check" />

    <CustomAction Id="SetRunHelperUninstall" Property="RunInstallerHelperUninstall" Value="--uninstall --install-dir &quot;[INSTALLDIR].&quot;" />
    <CustomAction Id="RunInstallerHelperUninstall" FileRef="InstallerHelperExe" ExeCommand="[RunInstallerHelperUninstall]" Execute="deferred" Impersonate="yes" Return="check" />

    <InstallExecuteSequence>
      <Custom Action="SetRunHelper" After="InstallFiles" Condition="NOT Installed" />
      <Custom Action="RunInstallerHelper" After="SetRunHelper" Condition="NOT Installed" />

      <Custom Action="SetRunHelperUninstall" Before="RemoveFiles" Condition="REMOVE=&quot;ALL&quot;" />
      <Custom Action="RunInstallerHelperUninstall" After="SetRunHelperUninstall" Condition="REMOVE=&quot;ALL&quot;" />
    </InstallExecuteSequence>
  </Package>
</Wix>
